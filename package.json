{
  "name": "fabric-mcp",
  "version": "0.1.0",
  "description": "MCP server for editing Fabric spatial scenes",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fabric-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && cp -r src/vendor dist/ && cp src/client/ManifolderClient.js dist/client/ManifolderClient.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --test src/client/ManifolderClient.test.js",
    "test:integration": "node --test --test-force-exit test/integration/ManifolderClient.integration.test.js",
    "test:record-fixtures": "node test/integration/record-manifolder-fixtures.js",
    "sync:manifolder-client": "cp ../Manifolder/client/js/ManifolderClient.js src/client/ManifolderClient.js",
    "check:manifolder-client-sync": "cmp -s ../Manifolder/client/js/ManifolderClient.js src/client/ManifolderClient.js || (echo 'ManifolderClient.js is out of sync. Run: npm run sync:manifolder-client' && exit 1)",
    "sync:mv-client": "npm run sync:manifolder-client",
    "check:mv-client-sync": "npm run check:manifolder-client-sync"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "socket.io-client": "^4.7.0",
    "ssh2-sftp-client": "^11.0.0",
    "ws": "^8.19.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ssh2-sftp-client": "^9.0.0",
    "typescript": "^5.6.0"
  }
}
