{
  "name": "manifolder-mcp",
  "version": "0.1.0",
  "description": "Manifolder MCP server for editing Fabric spatial scenes",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "manifolder-mcp": "dist/index.js"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "npm run build && node --test test/mcp-tools.test.js test/integration/mcp-tools-e2e.integration.test.js",
    "test:integration": "npm run build && node --test --test-force-exit test/integration/ManifolderClient.integration.test.js",
    "test:record-fixtures": "node test/integration/record-manifolder-fixtures.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "socket.io-client": "^4.7.0",
    "ssh2-sftp-client": "^11.0.0",
    "ws": "^8.19.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ssh2-sftp-client": "^9.0.0",
    "typescript": "^5.6.0"
  }
}
